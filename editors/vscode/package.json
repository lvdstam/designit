{
    "name": "designit",
    "displayName": "DesignIt",
    "description": "Language support for DesignIt - Yourdon-style design documents",
    "version": "0.1.0",
    "publisher": "designit",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Linters"
    ],
    "activationEvents": [
        "onLanguage:designit"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "designit",
                "aliases": [
                    "DesignIt",
                    "designit"
                ],
                "extensions": [
                    ".dit"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "designit",
                "scopeName": "source.designit",
                "path": "./syntaxes/designit.tmLanguage.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "DesignIt",
            "properties": {
                "designit.server.path": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the DesignIt language server (leave empty to use bundled server)"
                },
                "designit.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces the communication between VS Code and the language server"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.75.0",
        "typescript": "^5.0.0"
    }
}
