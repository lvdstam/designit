{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "DesignIt",
    "scopeName": "source.designit",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#operators" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.designit",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.designit",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.designit",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.designit",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.designit",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.designit",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.import.designit",
                    "match": "\\b(import)\\b"
                },
                {
                    "name": "keyword.declaration.designit",
                    "match": "\\b(dfd|erd|std|structure|datadict)\\b"
                },
                {
                    "name": "keyword.element.dfd.designit",
                    "match": "\\b(external|process|datastore|flow)\\b"
                },
                {
                    "name": "keyword.element.erd.designit",
                    "match": "\\b(entity|relationship)\\b"
                },
                {
                    "name": "keyword.element.std.designit",
                    "match": "\\b(state|transition|initial)\\b"
                },
                {
                    "name": "keyword.element.structure.designit",
                    "match": "\\b(module|calls|data_couple|control_couple)\\b"
                },
                {
                    "name": "keyword.constraint.designit",
                    "match": "\\b(pk|fk|unique|not null|pattern|optional|min|max)\\b"
                },
                {
                    "name": "keyword.property.designit",
                    "match": "\\b(description|trigger|guard|action|entry|exit|inputs|outputs)\\b"
                },
                {
                    "name": "keyword.placeholder.designit",
                    "match": "\\b(TBD)\\b|\\.\\.\\.(?!\\w)"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.designit",
                    "match": "\\b(string|integer|decimal|boolean|datetime|date|time|binary)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.designit",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.numeric.designit",
                    "match": "-?\\d+(\\.\\d+)?"
                },
                {
                    "name": "constant.cardinality.designit",
                    "match": "\\b(1|n|m|0\\.\\.1|0\\.\\.n|1\\.\\.n)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.designit",
                    "match": "->|-->"
                },
                {
                    "name": "keyword.operator.assignment.designit",
                    "match": "="
                },
                {
                    "name": "keyword.operator.union.designit",
                    "match": "\\|"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "entity.name.type.designit",
                    "match": "(?<=\\b(dfd|erd|std|structure|entity|process|external|datastore|state|module)\\s+)\\w+"
                },
                {
                    "name": "variable.other.designit",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
