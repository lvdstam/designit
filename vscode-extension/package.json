{
    "name": "designit",
    "displayName": "DesignIt",
    "description": "Language support for DesignIt DSL - Yourdon-style design documents",
    "version": "0.1.0",
    "publisher": "designit",
    "license": "MIT",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "designit",
        "dsl",
        "yourdon",
        "dfd",
        "erd",
        "data flow diagram",
        "entity relationship"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/yourusername/designit"
    },
    "activationEvents": [
        "onLanguage:designit"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "designit",
                "aliases": [
                    "DesignIt",
                    "designit"
                ],
                "extensions": [
                    ".dit"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "designit",
                "scopeName": "source.designit",
                "path": "./syntaxes/designit.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "DesignIt",
            "properties": {
                "designit.server.path": {
                    "type": "string",
                    "default": "designit",
                    "description": "Path to the designit executable. If not set, uses 'designit' from PATH."
                },
                "designit.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces the communication between VS Code and the DesignIt language server."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package-extension",
        "compile": "node esbuild.js",
        "watch": "node esbuild.js --watch",
        "package-extension": "node esbuild.js --production",
        "lint": "eslint src --ext ts",
        "package": "npm run package-extension && vsce package",
        "publish": "npm run package-extension && vsce publish"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/vscode": "^1.75.0",
        "@vscode/vsce": "^2.22.0",
        "esbuild": "^0.27.2",
        "typescript": "^5.3.0"
    }
}
